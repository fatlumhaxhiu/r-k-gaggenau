generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  full_name     String?   @db.VarChar(255)
  role          String?   @default("admin") @db.VarChar(50)
  avatar_url    String?   @db.Text
  last_login_at DateTime? @db.Timestamptz
  created_at    DateTime? @default(now()) @db.Timestamptz
  updated_at    DateTime? @default(now()) @db.Timestamptz

  leads         Lead[]
  blog_posts    BlogPost[]
  sessions      Session[]

  @@map("admins")
}

model Session {
  id         String   @id @db.Uuid
  admin_id   String   @db.Uuid
  token      String   @unique @db.Text
  expires_at DateTime @db.Timestamptz
  created_at DateTime @default(now()) @db.Timestamptz

  admin Admin @relation(fields: [admin_id], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Lead {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name        String    @db.VarChar(100)
  last_name         String    @db.VarChar(100)
  email             String    @db.VarChar(255)
  phone             String?   @db.VarChar(50)
  service_requested String?   @db.VarChar(100)
  source_page       String?   @db.VarChar(255)
  message           String?   @db.Text
  status            String?   @default("new") @db.VarChar(50)
  assigned_to       String?   @db.Uuid
  notes             String?   @db.Text
  lead_score        Int?      @default(0)
  responded_at      DateTime? @db.Timestamptz
  converted_at      DateTime? @db.Timestamptz
  created_at        DateTime? @default(now()) @db.Timestamptz
  updated_at        DateTime? @default(now()) @db.Timestamptz

  assigned_admin Admin? @relation(fields: [assigned_to], references: [id])

  @@map("leads")
}

model BlogPost {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title           String    @db.VarChar(500)
  slug            String    @unique @db.VarChar(500)
  excerpt         String?   @db.Text
  content         String?   @db.Text
  cover_image_url String?   @db.Text
  category        String?   @db.VarChar(100)
  status          String?   @default("draft") @db.VarChar(50)
  author_id       String?   @db.Uuid
  views_count     Int?      @default(0)
  published_at    DateTime? @db.Timestamptz
  created_at      DateTime? @default(now()) @db.Timestamptz
  updated_at      DateTime? @default(now()) @db.Timestamptz

  author Admin? @relation(fields: [author_id], references: [id])

  @@map("blog_posts")
}

model ContactSubmission {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @db.VarChar(255)
  email      String    @db.VarChar(255)
  phone      String?   @db.VarChar(50)
  subject    String?   @db.VarChar(500)
  message    String    @db.Text
  is_read    Boolean   @default(false)
  created_at DateTime? @default(now()) @db.Timestamptz

  @@map("contact_submissions")
}
